# Vercel sends this secret as: Authorization: Bearer <CRON_SECRET>
CRON_SECRET=

# Fine-grained GitHub token with Contents: Read and write for this repository.
GITHUB_TOKEN=

GITHUB_OWNER=defffis
GITHUB_REPO=Open-ipa-Library
GITHUB_BRANCH=main
GITHUB_OUTPUT_PATH=output/catalog.json
GITHUB_SOURCES_PATH=config/sources.json
GITHUB_DEFAULTS_PATH=config/defaults.json

# Safety limits.
MIN_APPLICATIONS=1
MAX_REMOVAL_PERCENT=70
SOURCE_TIMEOUT_MS=20000
SOURCE_CONCURRENCY=4
